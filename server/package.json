{
  "name": "knowledge-detective-server",
  "version": "1.0.0",
  "description": "知识侦探 - 生产级 TypeScript 后端服务",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run --pool=forks",
    "test:watch": "vitest --pool=forks"
  },
  "keywords": [
    "knowledge-detective",
    "education",
    "game",
    "typescript",
    "express"
  ],
  "author": "知识侦探团队",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "mysql2": "^3.10.1",
    "pdf-parse": "^2.4.5",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.8",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
